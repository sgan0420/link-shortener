<% presenter = ShortLinkPresenter.new(short_link,
                                       host: request.host_with_port,
                                       scheme: request.scheme) %>

<article id="<%= dom_id(short_link) %>"
         class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm"
         data-controller="history-recorder"
         data-history-recorder-slug-value="<%= short_link.slug %>"
         data-history-recorder-target-value="<%= short_link.target_url %>"
         data-history-recorder-short-url-value="<%= presenter.short_url %>">
  <%# Subscribe this card to Turbo Stream broadcasts for the link, so
      FetchTitleJob's broadcast_replace_to updates the title slot live. %>
  <%= turbo_stream_from short_link %>

  <div class="flex items-baseline justify-between gap-4">
    <a href="<%= presenter.short_url %>"
       target="_blank"
       rel="noopener noreferrer"
       class="truncate text-lg font-mono text-slate-900 underline decoration-slate-300 hover:decoration-slate-900">
      <%= presenter.short_url %>
    </a>
    <%= link_to "View stats",
                stats_path(slug: short_link.slug),
                class: "shrink-0 text-sm text-slate-500 hover:text-slate-900" %>
  </div>

  <p class="mt-1 truncate text-sm text-slate-500" title="<%= short_link.target_url %>">
    <%= presenter.display_target %>
  </p>

  <p class="mt-3">
    <%= render "title", short_link: short_link %>
  </p>
</article>
